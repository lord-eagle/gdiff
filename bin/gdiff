#!/usr/bin/env bash
# gdiff — open the current repo's git diff as a side-by-side HTML view in your browser.
#
# Usage:
#   gdiff                # working tree + staged diff vs HEAD
#   gdiff <ref>          # diff vs <ref> (e.g. gdiff main, gdiff HEAD~3)
#   gdiff <a> <b>        # diff between two refs
#   gdiff --unified      # plain colored unified diff in terminal (no browser)
#   gdiff --help

set -euo pipefail

print_help() {
  cat <<'EOF'
gdiff — git diff as a beautiful side-by-side HTML view

Usage:
  gdiff                  Show working tree + staged changes
  gdiff <ref>            Diff vs <ref> (e.g. main, HEAD~3, origin/main)
  gdiff <a> <b>          Diff between two refs
  gdiff -u, --unified    Plain colored unified diff in terminal
  gdiff -h, --help       Show this help

Requires: git, node (for npx). On first run npx fetches diff2html-cli (cached after).

Environment:
  GDIFF_OPEN=0          Skip opening the browser; print the HTML path instead.
EOF
}

mode="html"
args=()
for arg in "$@"; do
  case "$arg" in
    -h|--help) print_help; exit 0 ;;
    -u|--unified) mode="unified" ;;
    *) args+=("$arg") ;;
  esac
done

if ! git rev-parse --git-dir >/dev/null 2>&1; then
  echo "gdiff: not inside a git repository" >&2
  exit 1
fi

collect_diff() {
  local color_flag="${1:-never}"
  if [ "${#args[@]}" -eq 0 ]; then
    git --no-pager diff "--color=$color_flag"
    git --no-pager diff --cached "--color=$color_flag"
  elif [ "${#args[@]}" -eq 1 ]; then
    git --no-pager diff "--color=$color_flag" "${args[0]}"
  else
    git --no-pager diff "--color=$color_flag" "${args[0]}" "${args[1]}"
  fi
}

if [ "$mode" = "unified" ]; then
  collect_diff always
  exit 0
fi

if ! command -v npx >/dev/null 2>&1; then
  echo "gdiff: 'npx' not found. Install Node.js (https://nodejs.org) or run with --unified." >&2
  exit 1
fi

tmp_dir="$(mktemp -d -t gdiff.XXXXXX)"
out="$tmp_dir/diff.html"

diff_text="$(collect_diff never)"
if [ -z "$diff_text" ]; then
  echo "gdiff: no changes to show."
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"
repo_name="$(basename "$repo_root")"
title="gdiff — $repo_name"

# Stable per-(repo, diff-args) key so localStorage comments survive reruns.
storage_seed="$repo_root|${args[*]-}"
if command -v shasum >/dev/null 2>&1; then
  storage_id="$(printf '%s' "$storage_seed" | shasum -a 1 | awk '{print $1}')"
elif command -v sha1sum >/dev/null 2>&1; then
  storage_id="$(printf '%s' "$storage_seed" | sha1sum | awk '{print $1}')"
else
  storage_id="$(printf '%s' "$storage_seed" | od -An -tx1 | tr -d ' \n' | cut -c1-40)"
fi

add_review_tools() {
  cat >>"$out" <<EOF
<script>window.__gdiffStorageKey = "gdiff-review-comments:$storage_id";</script>
EOF
  cat >>"$out" <<'EOF'
<style>
  .gdiff-review-bar {
    position: fixed;
    right: 16px;
    bottom: 16px;
    z-index: 20;
    display: flex;
    gap: 8px;
    align-items: center;
    padding: 8px;
    background: #24292f;
    border-radius: 6px;
    box-shadow: 0 8px 24px rgba(140, 149, 159, 0.35);
    color: #fff;
    font: 13px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }
  .gdiff-review-bar button,
  .gdiff-review-panel button {
    border: 1px solid #d0d7de;
    border-radius: 6px;
    background: #f6f8fa;
    color: #24292f;
    cursor: pointer;
    font: inherit;
    padding: 6px 10px;
  }
  .gdiff-review-bar button:hover,
  .gdiff-review-panel button:hover {
    background: #eef1f4;
  }
  .gdiff-review-bar .gdiff-primary,
  .gdiff-review-panel .gdiff-primary {
    border-color: #1f883d;
    background: #1f883d;
    color: #fff;
  }
  .gdiff-review-bar .gdiff-primary:hover,
  .gdiff-review-panel .gdiff-primary:hover {
    background: #1a7f37;
  }
  .gdiff-review-panel {
    width: min(720px, calc((100vw - 80px) / 2));
    max-width: calc(100vw - 80px);
    box-sizing: border-box;
    padding: 12px;
    border: 1px solid #d0d7de;
    border-radius: 6px;
    background: #fff;
    color: #24292f;
    font: 13px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }
  .gdiff-review-editor-row > td {
    padding: 8px 12px;
    background: #f6f8fa;
    vertical-align: top;
  }
  .gdiff-review-spacer-row > td {
    padding: 0;
    border: 0;
  }
  .gdiff-review-target {
    margin: 0 0 8px;
    color: #57606a;
    overflow-wrap: anywhere;
  }
  .gdiff-review-code {
    margin: 0 0 8px;
    max-height: 110px;
    overflow: auto;
    padding: 8px;
    border-radius: 6px;
    background: #f6f8fa;
    color: #24292f;
    font: 12px ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    white-space: pre-wrap;
  }
  .gdiff-review-panel textarea {
    width: 100%;
    min-height: 110px;
    box-sizing: border-box;
    resize: vertical;
    margin: 0 0 8px;
    padding: 8px;
    border: 1px solid #d0d7de;
    border-radius: 6px;
    color: #24292f;
    font: inherit;
  }
  .gdiff-review-actions {
    display: flex;
    gap: 8px;
    justify-content: flex-end;
  }
  .gdiff-selected-line > td {
    background: #ddf4ff !important;
    box-shadow: inset 3px 0 #0969da;
  }
  .gdiff-commented-line {
    background: #fff8c5 !important;
    box-shadow: inset 3px 0 #d4a72c;
  }
  .gdiff-review-delete {
    border-color: #cf222e !important;
    color: #cf222e;
    margin-right: auto;
  }
  .gdiff-review-delete[disabled] {
    opacity: 0.4;
    cursor: not-allowed;
  }
  .gdiff-review-panel button[disabled] {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .gdiff-copy-modal {
    position: fixed;
    inset: 0;
    z-index: 30;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(15, 20, 25, 0.55);
  }
  .gdiff-copy-modal .gdiff-review-panel {
    width: min(640px, calc(100vw - 48px));
  }
  .gdiff-copy-modal textarea {
    min-height: 220px;
    font: 12px ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }
  .gdiff-copy-hint {
    margin: 0 0 8px;
    color: #57606a;
    font-size: 12px;
  }
  @media (prefers-color-scheme: dark) {
    .gdiff-review-panel {
      border-color: #30363d;
      background: #161b22;
      color: #e6edf3;
    }
    .gdiff-review-editor-row > td {
      background: #0d1117;
    }
    .gdiff-review-target {
      color: #8b949e;
    }
    .gdiff-review-code,
    .gdiff-review-panel textarea {
      border-color: #30363d;
      background: #0d1117;
      color: #e6edf3;
    }
    .gdiff-commented-line {
      background: rgba(210, 153, 34, 0.25) !important;
      box-shadow: inset 3px 0 #d29922;
    }
    .gdiff-selected-line > td {
      background: rgba(56, 139, 253, 0.18) !important;
    }
    .gdiff-copy-hint {
      color: #8b949e;
    }
  }
</style>
<script>
(function () {
  // DOM hooks below (.d2h-*) are diff2html-cli class names; if that library
  // changes its markup we need to update the selectors in lockstep.
  var comments = new Map();
  var currentSelection = null;
  var anchorTarget = null;
  var dragTarget = null;
  var isDragging = false;
  var storageKey = window.__gdiffStorageKey ||
    ("gdiff-review-comments:" + location.pathname);

  function text(node) {
    return (node && node.textContent ? node.textContent : "").replace(/\u00a0/g, " ").trim();
  }

  function lineKind(row) {
    var codeCell = row.querySelector("td:nth-child(2)");
    if (!codeCell) return "context";
    if (codeCell.classList.contains("d2h-ins")) return "added";
    if (codeCell.classList.contains("d2h-del")) return "removed";
    if (codeCell.classList.contains("d2h-info")) return "hunk";
    return "context";
  }

  function fileName(wrapper) {
    return text(wrapper.querySelector(".d2h-file-header .d2h-file-name")) || "unknown";
  }

  function lineCode(row) {
    var code = row.querySelector(".d2h-code-line-ctn");
    if (!code) return text(row.querySelector(".d2h-code-side-line, .d2h-code-line"));
    return code.textContent.replace(/\u00a0/g, " ");
  }

  function targetFromRow(row) {
    var cell = row && row.querySelector(".d2h-code-side-linenumber, .d2h-code-linenumber");
    if (!cell) return null;
    var parentRow = cell.closest("tr");
    var wrapper = cell.closest(".d2h-file-wrapper");
    var sideDiff = cell.closest(".d2h-file-side-diff");
    var line = text(cell);
    if (!parentRow || !wrapper || !line || !/^\d+$/.test(line)) return null;
    var side = "new";
    if (sideDiff) {
      side = Array.prototype.indexOf.call(sideDiff.parentElement.children, sideDiff) === 0 ? "old" : "new";
    } else if (cell.querySelector(".line-num1") && !cell.querySelector(".line-num2")) {
      side = "old";
    }
    var file = fileName(wrapper);
    var kind = lineKind(parentRow);
    return {
      id: [file, side, line, kind].join(":"),
      file: file,
      side: side,
      line: Number(line),
      kind: kind,
      code: lineCode(parentRow),
      row: parentRow,
      cell: cell
    };
  }

  function targetFromEvent(event) {
    if (event.target.closest(".gdiff-review-panel, .gdiff-review-bar, .gdiff-copy-modal")) return null;
    // Restrict comment selection to the line-number gutter so users can still
    // text-select code in the diff body without triggering the editor.
    if (!event.target.closest(".d2h-code-side-linenumber, .d2h-code-linenumber")) return null;
    return targetFromRow(event.target.closest("tr"));
  }

  function allTargetsInTable(target) {
    return Array.prototype.slice.call(target.row.parentElement.querySelectorAll("tr"))
      .map(targetFromRow)
      .filter(function (candidate) {
        return candidate &&
          candidate.file === target.file &&
          candidate.side === target.side &&
          candidate.row.parentElement === target.row.parentElement;
      });
  }

  function visualRows(tbody) {
    if (!tbody) return [];
    return Array.prototype.slice.call(tbody.children).filter(function (row) {
      return row.id !== "gdiff-review-editor-row" && row.id !== "gdiff-review-spacer-row";
    });
  }

  function selectionFromTargets(start, end) {
    if (!start || !end || start.file !== end.file || start.side !== end.side) return null;
    if (start.row.parentElement !== end.row.parentElement) return null;
    var targets = allTargetsInTable(start);
    var startIndex = targets.findIndex(function (target) { return target.row === start.row; });
    var endIndex = targets.findIndex(function (target) { return target.row === end.row; });
    if (startIndex < 0 || endIndex < 0) return null;
    var selected = targets.slice(Math.min(startIndex, endIndex), Math.max(startIndex, endIndex) + 1);
    var lines = selected.map(function (target) { return target.line; });
    var kinds = selected.map(function (target) { return target.kind; });
    var kind = kinds.every(function (value) { return value === kinds[0]; }) ? kinds[0] : "mixed";
    var startLine = Math.min.apply(Math, lines);
    var endLine = Math.max.apply(Math, lines);
    return {
      id: [start.file, start.side, startLine + "-" + endLine, kind].join(":"),
      file: start.file,
      side: start.side,
      startLine: startLine,
      endLine: endLine,
      kind: kind,
      code: selected.map(function (target) { return target.code; }).join("\n"),
      rows: selected.map(function (target) { return target.row; }),
      cells: selected.map(function (target) { return target.cell; }),
      tableBody: start.row.parentElement,
      sidePane: start.row.closest(".d2h-file-side-diff"),
      rowIndex: visualRows(start.row.parentElement).indexOf(selected[selected.length - 1].row)
    };
  }

  function loadComments() {
    try {
      JSON.parse(localStorage.getItem(storageKey) || "[]").forEach(function (comment) {
        if (comment.side !== "old" && comment.side !== "new") return;
        if (!/^(added|removed|context|hunk|mixed)$/.test(comment.kind)) comment.kind = "mixed";
        if (!comment.startLine) comment.startLine = comment.line;
        if (!comment.endLine) comment.endLine = comment.line;
        comment.id = [comment.file, comment.side, comment.startLine + "-" + comment.endLine, comment.kind].join(":");
        comments.set(comment.id, comment);
      });
    } catch (error) {
      comments.clear();
    }
  }

  function saveComments() {
    localStorage.setItem(storageKey, JSON.stringify(Array.from(comments.values())));
  }

  function commentsByFileSide() {
    var grouped = new Map();
    comments.forEach(function (comment) {
      var key = comment.file + "␀" + comment.side;
      if (!grouped.has(key)) grouped.set(key, []);
      grouped.get(key).push(comment);
    });
    return grouped;
  }

  function refreshMarkers() {
    document.querySelectorAll(".gdiff-commented-line").forEach(function (cell) {
      cell.classList.remove("gdiff-commented-line");
      cell.removeAttribute("data-gdiff-comment-id");
    });
    var grouped = commentsByFileSide();
    var cells = document.querySelectorAll(".d2h-code-side-linenumber");
    for (var i = 0; i < cells.length; i++) {
      var cell = cells[i];
      var target = targetFromRow(cell.closest("tr"));
      if (!target) continue;
      var bucket = grouped.get(target.file + "␀" + target.side);
      if (!bucket) continue;
      for (var j = 0; j < bucket.length; j++) {
        var comment = bucket[j];
        var startLine = comment.startLine || comment.line;
        var endLine = comment.endLine || comment.line;
        if (target.line >= startLine && target.line <= endLine) {
          cell.classList.add("gdiff-commented-line");
          cell.setAttribute("data-gdiff-comment-id", comment.id);
          break;
        }
      }
    }
    document.getElementById("gdiff-review-count").textContent = String(comments.size);
  }

  function clearSelection() {
    document.querySelectorAll(".gdiff-selected-line").forEach(function (row) {
      row.classList.remove("gdiff-selected-line");
    });
  }

  function lineLabel(selection) {
    return selection.startLine === selection.endLine ? String(selection.startLine) : selection.startLine + "-" + selection.endLine;
  }

  function ensurePanelRow(selection) {
    var row = document.getElementById("gdiff-review-editor-row");
    var spacer = document.getElementById("gdiff-review-spacer-row");
    if (spacer) spacer.remove();
    if (!row) {
      row = document.createElement("tr");
      row.id = "gdiff-review-editor-row";
      row.className = "gdiff-review-editor-row";
      row.innerHTML = '<td colspan="2"><section id="gdiff-review-panel" class="gdiff-review-panel">' +
        '<p id="gdiff-review-target" class="gdiff-review-target"></p>' +
        '<pre id="gdiff-review-code" class="gdiff-review-code"></pre>' +
        '<textarea id="gdiff-review-comment" placeholder="Leave feedback for this line"></textarea>' +
        '<div class="gdiff-review-actions">' +
        '  <button type="button" id="gdiff-review-delete" class="gdiff-review-delete">Delete</button>' +
        '  <button type="button" id="gdiff-review-cancel">Cancel</button>' +
        '  <button type="button" id="gdiff-review-save" class="gdiff-primary">Save comment</button>' +
        '</div>' +
        '</section></td>';
      row.querySelector("#gdiff-review-save").addEventListener("click", saveCurrentComment);
      row.querySelector("#gdiff-review-cancel").addEventListener("click", closePanel);
      row.querySelector("#gdiff-review-delete").addEventListener("click", deleteCurrentComment);
      row.querySelector("#gdiff-review-comment").addEventListener("input", updatePanelButtons);
      row.querySelector("#gdiff-review-comment").addEventListener("keydown", function (event) {
        if ((event.metaKey || event.ctrlKey) && event.key === "Enter") saveCurrentComment();
        if (event.key === "Escape") closePanel();
      });
    }
    selection.rows[selection.rows.length - 1].after(row);
    if (selection.sidePane) {
      row.querySelector(".gdiff-review-panel").style.width = Math.max(180, selection.sidePane.clientWidth - 32) + "px";
      var panes = Array.prototype.slice.call(selection.sidePane.parentElement.querySelectorAll(".d2h-file-side-diff"));
      var siblingPane = panes.find(function (pane) { return pane !== selection.sidePane; });
      var siblingRows = siblingPane ? visualRows(siblingPane.querySelector("tbody.d2h-diff-tbody")) : [];
      var siblingRow = siblingRows[selection.rowIndex];
      if (siblingRow) {
        spacer = document.createElement("tr");
        spacer.id = "gdiff-review-spacer-row";
        spacer.className = "gdiff-review-spacer-row";
        spacer.innerHTML = '<td colspan="2"></td>';
        siblingRow.after(spacer);
        spacer.querySelector("td").style.height = row.getBoundingClientRect().height + "px";
      }
    }
    return row;
  }

  function previewSelection(selection) {
    if (!selection) return;
    clearSelection();
    selection.rows.forEach(function (row) {
      row.classList.add("gdiff-selected-line");
    });
  }

  function openPanel(selection) {
    currentSelection = selection;
    previewSelection(selection);
    ensurePanelRow(selection);
    document.getElementById("gdiff-review-target").textContent =
      selection.file + ":" + lineLabel(selection) + " (" + selection.side + ", " + selection.kind + ")";
    document.getElementById("gdiff-review-code").textContent = selection.code;
    document.getElementById("gdiff-review-comment").value = (comments.get(selection.id) || {}).comment || "";
    document.getElementById("gdiff-review-comment").focus();
    updatePanelButtons();
  }

  function updatePanelButtons() {
    if (!currentSelection) return;
    var textarea = document.getElementById("gdiff-review-comment");
    var saveBtn = document.getElementById("gdiff-review-save");
    var deleteBtn = document.getElementById("gdiff-review-delete");
    if (!textarea || !saveBtn || !deleteBtn) return;
    saveBtn.disabled = textarea.value.trim().length === 0;
    deleteBtn.disabled = !comments.has(currentSelection.id);
  }

  function closePanel() {
    var row = document.getElementById("gdiff-review-editor-row");
    var spacer = document.getElementById("gdiff-review-spacer-row");
    if (row) row.remove();
    if (spacer) spacer.remove();
    clearSelection();
    currentSelection = null;
  }

  function saveCurrentComment() {
    if (!currentSelection) return;
    var value = document.getElementById("gdiff-review-comment").value.trim();
    if (!value) return;
    comments.set(currentSelection.id, {
      id: currentSelection.id,
      file: currentSelection.file,
      side: currentSelection.side,
      startLine: currentSelection.startLine,
      endLine: currentSelection.endLine,
      kind: currentSelection.kind,
      code: currentSelection.code,
      comment: value
    });
    saveComments();
    refreshMarkers();
    closePanel();
  }

  function deleteCurrentComment() {
    if (!currentSelection || !comments.has(currentSelection.id)) return;
    comments.delete(currentSelection.id);
    saveComments();
    refreshMarkers();
    closePanel();
  }

  function buildPrompt() {
    var list = Array.from(comments.values()).sort(function (a, b) {
      return a.file.localeCompare(b.file) || (a.startLine || a.line) - (b.startLine || b.line) || a.side.localeCompare(b.side);
    });
    var xml = function (value) {
      return String(value).replace(/[<>&'"]/g, function (char) {
        return {
          "<": "&lt;",
          ">": "&gt;",
          "&": "&amp;",
          "'": "&apos;",
          "\"": "&quot;"
        }[char];
      });
    };
    var lines = [
      "Please address the following line-level review feedback from the git diff.",
      "",
      "Before editing, inspect all comments and target locations first so line numbers do not drift while you work.",
      "Then address the comments one by one.",
      "",
      "Return a concise summary of the changes you made and call out any feedback you could not apply.",
      "",
      "<review_feedback>"
    ];
    list.forEach(function (comment, index) {
      lines.push("  <comment index=\"" + (index + 1) + "\">");
      lines.push("    <file>" + xml(comment.file) + "</file>");
      lines.push("    <lines side=\"" + xml(comment.side) + "\" kind=\"" + xml(comment.kind) + "\" start=\"" + xml(comment.startLine || comment.line) + "\" end=\"" + xml(comment.endLine || comment.line) + "\" />");
      lines.push("    <code>" + xml(comment.code) + "</code>");
      lines.push("    <feedback>" + xml(comment.comment) + "</feedback>");
      lines.push("  </comment>");
    });
    lines.push("</review_feedback>");
    return lines.join("\n");
  }

  function flashCopiedButton() {
    var button = document.getElementById("gdiff-copy-comments");
    if (!button) return;
    var label = button.textContent;
    button.textContent = "Copied";
    setTimeout(function () { button.textContent = label; }, 1200);
  }

  function openCopyFallbackModal(text) {
    var existing = document.getElementById("gdiff-copy-modal");
    if (existing) existing.remove();
    var modal = document.createElement("div");
    modal.id = "gdiff-copy-modal";
    modal.className = "gdiff-copy-modal";
    modal.innerHTML = '<section class="gdiff-review-panel">' +
      '<p class="gdiff-copy-hint">Clipboard access was blocked (this often happens on <code>file://</code>). ' +
      'Press ' + (navigator.platform.indexOf("Mac") >= 0 ? "⌘C" : "Ctrl+C") + ' to copy, then close.</p>' +
      '<textarea readonly></textarea>' +
      '<div class="gdiff-review-actions">' +
      '  <button type="button" class="gdiff-primary" data-action="close">Close</button>' +
      '</div>' +
      '</section>';
    var textarea = modal.querySelector("textarea");
    textarea.value = text;
    modal.querySelector('[data-action="close"]').addEventListener("click", function () {
      modal.remove();
    });
    modal.addEventListener("click", function (event) {
      if (event.target === modal) modal.remove();
    });
    document.body.appendChild(modal);
    textarea.focus();
    textarea.select();
  }

  function copyComments() {
    var promptText = comments.size ? buildPrompt() : "No gdiff review comments have been added.";
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(promptText).then(flashCopiedButton, function () {
        openCopyFallbackModal(promptText);
      });
    } else {
      openCopyFallbackModal(promptText);
    }
  }

  function clearComments() {
    if (!comments.size || !confirm("Clear all gdiff review comments?")) return;
    comments.clear();
    saveComments();
    refreshMarkers();
    closePanel();
  }

  function addUi() {
    var bar = document.createElement("div");
    bar.className = "gdiff-review-bar";
    bar.innerHTML = [
      '<span><span id="gdiff-review-count">0</span> comments</span>',
      '<button type="button" id="gdiff-copy-comments" class="gdiff-primary">Copy prompt</button>',
      '<button type="button" id="gdiff-clear-comments">Clear</button>'
    ].join("");
    document.body.appendChild(bar);

    document.getElementById("gdiff-copy-comments").addEventListener("click", copyComments);
    document.getElementById("gdiff-clear-comments").addEventListener("click", clearComments);
  }

  document.addEventListener("mousedown", function (event) {
    var target = targetFromEvent(event);
    if (!target) return;
    dragTarget = target;
    isDragging = true;
    if (!event.shiftKey) anchorTarget = target;
    event.preventDefault();
    previewSelection(selectionFromTargets(anchorTarget, target));
  });

  document.addEventListener("mouseover", function (event) {
    if (!isDragging || !dragTarget) return;
    var target = targetFromEvent(event);
    if (!target || target.row === dragTarget.row) return;
    dragTarget = target;
    previewSelection(selectionFromTargets(anchorTarget, target));
  });

  document.addEventListener("mouseup", function (event) {
    if (!isDragging) return;
    isDragging = false;
    var target = targetFromEvent(event) || dragTarget;
    var start = event.shiftKey && anchorTarget ? anchorTarget : anchorTarget || target;
    var selection = selectionFromTargets(start, target);
    if (!selection) return;
    anchorTarget = target;
    openPanel(selection);
  });

  loadComments();
  addUi();
  refreshMarkers();
})();
</script>
EOF
}

printf '%s' "$diff_text" | npx --yes diff2html-cli@^5.2 \
  --style side \
  --highlightCode true \
  --summary closed \
  --title "$title" \
  -i stdin \
  -F "$out" >/dev/null

add_review_tools

if [ "${GDIFF_OPEN:-1}" = "0" ]; then
  echo "Open: $out"
  exit 0
fi

case "$(uname -s)" in
  Darwin) open "$out" ;;
  Linux)  xdg-open "$out" >/dev/null 2>&1 || echo "Open: $out" ;;
  *)      echo "Open: $out" ;;
esac
